extends ../layouts/default.pug

block main
  .login-container
    h2 Đăng nhập Admin
    form(method="POST", action="/admin/login")
      .form-group
        label(for="username") Tên đăng nhập
        input#username.form-control(type="text", name="username", required)
      .form-group
        label(for="password") Mật khẩu
        input#password.form-control(type="password", name="password", required)
      button.btn.btn-primary(type="submit") Đăng nhập
      if error
        .alert.alert-danger #{error}
