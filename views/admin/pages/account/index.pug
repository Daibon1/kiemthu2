extends ../../layouts/default.pug 
include ../../mixins/filter-status.pug
include ../../mixins/filter-search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug

block main 
  +alert-success(2000)
  +alert-error(2000)

  main.main
    // Header
    header.admin-header.d-flex.flex-wrap.justify-content-between.align-items-center.mb-3.gap-2
      h4.mb-0 Danh sách tài khoản
      a(href=`/${prefixAdmin}/account/create` class="btn btn-primary") Tạo tài khoản

    .table-card
      .table-scroll
        .table-responsive
          table(class="table align-middle mb-0" checkbox-multi)
            thead.table-light.sticky-top
              tr
                th 
                  input(type="checkbox" name="checkbox-all")
                th STT
                th Avatar
                th Họ tên
                th Email
                th Phân quyền
                th Số điện thoại
                th Trạng thái
                th Hành động

            tbody
              each item,index in accounts
                tr
                  td 
                    input(type="checkbox" name="id" value=item.id)

                  td #{(pagination.page-1)*pagination.limitItem+index+1}

                  td 
                    if item.avatar
                      img(
                        src=item.avatar 
                        alt=item.title 
                        class="img-fluid rounded"
                        style="max-width: 60px; height: auto;"
                      )
                    else
                      img(
                        src="/admin/images/no-image.png" 
                        alt="No Image" 
                        class="img-fluid rounded"
                        style="max-width: 60px; height: auto;"
                      )

                  td.text-truncate(style="max-width: 150px;") #{item.fullName}
                  td.text-truncate(style="max-width: 180px;") #{item.email}
                  td #{item.role}
                  td #{item.phone}

                  td
                    if(item.status=="active")
                      a.btn(
                        data-id=item.id
                        href="javascript:;"
                        class="badge bg-success"
                        change-status
                        data-status=item.status
                      ) Hoạt động
                    else
                      a.btn(
                        href="javascript:;"
                        class="badge bg-danger"
                        change-status
                        data-id=item.id
                        data-status=item.status
                      ) Ngừng hoạt động

                  td.text-end
                    .d-flex.flex-wrap.gap-1.justify-content-end
                      a(class="btn btn-outline-primary btn-sm"
                        href=`/${prefixAdmin}/account/edit/${item.id}`) Sửa
                      button(class="btn btn-outline-danger btn-sm"
                        button-delete
                        data-id=item.id) Xóa
    +pagination(pagination)