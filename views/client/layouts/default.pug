doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title #{title || "Website tuyển dụng"}

    // Bootstrap cơ bản
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="/css/style.css")

  body

    // ===== NAVBAR =====
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/") JobSite
        button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#nav")
          span.navbar-toggler-icon
        #nav.collapse.navbar-collapse
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href="/jobs") Việc làm
            li.nav-item
              a.nav-link(href="/about") Giới thiệu
            li.nav-item
              a.nav-link(href="/login") Đăng nhập

    main.container.mt-4
      block main

    footer.bg-light.text-center.py-3.mt-5
      p.mb-0 © 2026 Website tuyển dụng
    script(src="/js/script.js") 